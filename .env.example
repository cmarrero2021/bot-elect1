# Configuración del Bot WhatsApp - Arquitectura Hexagonal

# === CONFIGURACIÓN DE WHATSAPP ===
# Nombre del grupo objetivo a monitorear
GRUPO_OBJETIVO=PRUEBA

# Configuración de Puppeteer (true para headless, false para mostrar navegador)
PUPPETEER_HEADLESS=true

# === CONFIGURACIÓN DE BASE DE DATOS ===
# Credenciales de PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_NAME=_bot
DB_PASSWORD=postgres
DB_PORT=5432

# === CONFIGURACIÓN DE ARCHIVOS ===
# Ruta del archivo JSON para almacenar grupos detectados
GRUPOS_FILE=./grupos_detectados.json
